# 自动检测文本文件类型
* text=auto

# Python 文件使用 LF 换行符
*.py text eol=lf
*.txt text eol=lf
*.md text eol=lf

# JSON 文件（配置文件）
*.json text eol=lf

# 图片文件作为二进制文件
*.png binary
*.jpg binary
*.jpeg binary

# 视频文件作为二进制文件（如果有的话）
*.mp4 binary
*.avi binary
*.mkv binary

# 缓存分片文件 - 标记为大文件
video_cache_shards/** filter=lfs diff=lfs merge=lfs -text
